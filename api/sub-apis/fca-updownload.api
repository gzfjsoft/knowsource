type GetVerifyIdcardListDataItem {
	Id          uint64  `json:"id"`
	UserId      int64   `json:"user_id"`
	ReqName     string  `json:"req_name"`
	ReqIdcardNum string  `json:"req_idcard_num"`
	ImageFront string  `json:"image_front"`
	ImageBack string  `json:"image_back"`
	AuditStatus int64   `json:"audit_status"`
	FailReason string  `json:"fail_reason"`
	State int64   `json:"state"`
	CreatedAt   int64   `json:"created_at"`
	UpdatedAt   int64   `json:"updated_at"`
	Address string  `json:"address"`
	Birthday string  `json:"birthday"`
	ValidityPeriod string  `json:"validity_period"`
	Name string  `json:"name"`
	Gender int64   `json:"gender"`
	IssuingAuthority string  `json:"issuing_authority"`
	Ethnicity string  `json:"ethnicity"`
	IdcardNum string  `json:"idcard_num"`
	AuditUserId uint64  `json:"audit_user_id"`
	AuditAt     int64   `json:"audit_at"`

}

@server (
	prefix:     /api/v1
	timeout:    15s
)

service fca-api {
	@handler DownloadHandler
	get /file/static/:file(DownloadRequest)

	
}

@server (
	jwt:        Auth
	prefix:     /api/v1
	middleware: AuthInterceptor
	timeout:    60s
)
service fca-api {

	@handler UploadHandler
	post /upload returns (UploadResponse)

	@handler UploadIdcardFrontHandler
	post /upload/idcard/front returns (UploadResponse)

	@handler UploadIdcardBackHandler
	post /upload/idcard/back returns (UploadResponse)


	@handler VerifyIdcardHandler
	post /idcard/verify (VerifyRequest) returns (Response)

	@handler GetVerifyIdcardHandler
	post /idcard/verify/get (GetVerifyIdcardRequest) returns (GetVerifyIdcardResponse)
}

type AdminAduitIdcardRequest {
	Id uint64 `json:"id"`
	AuditStatus int64 `json:"audit_status"`
	FailReason string `json:"fail_reason"`
}


@server (
	jwt:        Auth
	prefix:     /api/v1
	middleware: AuthInterceptor
	group:      admin
	timeout:    60s
)
service fca-api {

	@handler GetVerifyIdcardListHandler
	post /admin/idcard/verify/list (GetVerifyIdcardListRequest) returns (GetVerifyIdcardListResponse)

	@handler AdminAduitIdcardHandler
	post /admin/idcard/audit (	AdminAduitIdcardRequest) returns (Response)
}