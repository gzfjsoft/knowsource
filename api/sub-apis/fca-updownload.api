syntax = "v1"

info(
    title: "Upload Download API"
    desc: "文件上传下载和身份证验证服务API"
    author: "PeterSZW"
    version: "1.0"
    filename: "fca-updownload.api"
)

type DownloadRequest {
	File string `path:"file"`
}

type UploadResponse {
	Response
	Filename string `json:"filename"`
	//Code int `json:"code"`
}
type VerifyRequest {
	IdcardFront string `json:"idcard_front"`
	IdcardBack  string `json:"idcard_back"`
	Name        string `json:"name"`
	Idcard      string `json:"idcard"`
}
type GetVerifyIdcardRequest {
	
}
type GetVerifyIdcardData {
	Id          uint64  `json:"id"`
	IdcardFront string `json:"idcard_front"`
	IdcardBack  string `json:"idcard_back"`
	Name        string `json:"name"`
	Idcard      string `json:"idcard"`
}
type GetVerifyIdcardResponse {
	Response
	Data *GetVerifyIdcardData `json:"data,optional"`
	
}
type GetVerifyIdcardListRequest {
	Page int64 `json:"page"`
	PageSize int64 `json:"page_size"`
}
type GetVerifyIdcardListResponse {
	Response
	Data  *GetVerifyIdcardListData`json:"data"`
	
}

type GetVerifyIdcardListData {
	 List []GetVerifyIdcardListDataItem `json:"list"`
	 Total int64 `json:"total"`
}


