type TransactionRecordsListRequest {
	OrgId          uint64 `json:"orgId,optional"`
	TransType      uint64 `json:"transType,optional"`
	CurrencyCode   string `json:"currencyCode,optional"`
	BeginCreatedAt uint64 `json:"beginCreatedAt,optional"`
	EndCreatedAt   uint64 `json:"endCreatedAt,optional"`
	OrderNo        string `json:"orderNo,optional"`
	PageRequest
}

type TransactionRecords {
	Id           uint64 `json:"id"`
	UserId       uint64 `json:"userId"`
	OrgId        uint64 `json:"orgId"`
	CreatedAt    uint64 `json:"createdAt"`
	TransType    uint64 `json:"transType"`
	PayType      string `json:"payType"`
	CurrencyCode string `json:"currencyCode"`
	Detail       string `json:"detail"`
	OrderNo      string `json:"orderNo"`
	Username     string `json:"username"`
	Amount       int64  `json:"amount"`
	Balance      int64  `json:"balance"`
}

type TransactionRecordsListResponse {
	Response
	Data TransactionRecordsListResponseData `json:"data,omitempty"`
}

type TransactionRecordsListResponseData {
	Trans []TransactionRecords `json:"trans"`
	Total int                  `json:"total"`
}

