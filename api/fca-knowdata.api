	Data Organization `json:"data,omitempty"`
}

type Organization {
	OrgId     uint64 `json:"orgId"`
	OrgName   string `json:"orgName"`
	CreatedBy uint64 `json:"createdBy"`
	UpdatedAt uint64 `json:"updatedAt"`
	CreatedAt uint64 `json:"createdAt"`
	IsPrivate uint64 `json:"isPrivate"`
	IsDefault uint64 `json:"isDefault"`
	Username  string `json:"username"`
}

type CreateOrgRequest {
	OrgName   string `json:"orgName"`
	IsPrivate uint64 `json:"isPrivate"`
	IsDefault uint64 `json:"isDefault,optional"`
}

type UpdateOrgRequest {
	OrgId     uint64 `json:"orgId"`
	OrgName   string `json:"orgName"`
	IsPrivate uint64 `json:"isPrivate"`
	IsDefault uint64 `json:"isDefault"`
}

type ListOrgRequest {
	PageRequest
}

type ListOrgResp {
	Response
	Data ListOrgRespData `json:"data,omitempty"`
}

type ListOrgRespData {
	Orgs  []Organization `json:"orgs"`
	Total int            `json:"total"`
}

type DeleteOrgRequest {
	OrgId uint64 `json:"orgId"`
}
 

