	// UserId uint64 `json:"userId" validate:"required"`
	UserIds []uint64 `json:"userIds"`
// Email  string `json:"email,optional"`
}

type AdminUserListRequest {
	Username string `json:"username,optional"`
	Email    string `json:"email,optional"`
	Phone    string `json:"phone,optional"`
	PageRequest
}

type AdminUserBalanceRequest {
	UserId uint64 `json:"userId"`
}

type AdminUserBalanceResponse {
	Response
	Data *AdminUserBalanceResponseData `json:"data,omitempty"`
}

type AdminUserBalanceResponseData {
	UserBalance []UserBalance `json:"userBalance"`
}

type AdminUserListResponse {
	Response
	Data AdminUserListResponseData `json:"data,omitempty"`
}

type AdminUserUpdateRequest {
	UserId    uint64 `json:"userId"`
	Username  string `json:"username,optional"`
	Nickname  string `json:"nickname,optional"`
	Phone     string `json:"phone,optional"`
	Email     string `json:"email,optional"`
	IsDeleted uint64 `json:"isDeleted,optional"`
	SysRole   string `json:"sysRole,optional"`
}

type AdminUserListResponseData {
	Users []UserResponseData `json:"users"`
	Total uint64             `json:"total"`
}

type ServerListRequest {
	RegionId     int      `json:"regionId,optional"`
	TagId        int      `json:"tagId,optional"`
	IsPayMin     int      `json:"isPayMin,optional"`
	IsPayDaily   int      `json:"isPayDaily,optional"`
	IsPayMonthly int      `json:"isPayMonthly,optional"`
	IsPayYearly  int      `json:"isPayYearly,optional"`
	GpuModel     []string `json:"gpuModel,optional"`
	GpuCount     int      `json:"gpuCount,optional"`
	GpuMem       int      `json:"gpuMem,optional"`
	CpuModel     []string `json:"cpuModel,optional"`
	CpuCores     int      `json:"cpuCores,optional"`
	Supplier     int      `json:"supplier,optional"`
	PageRequest
}

type ServerListDataResp {
	Servers   []Server `json:"servers"`
	PageIndex int      `json:"pageIndex"`
	PageSize  int      `json:"pageSize"`
	Offset    int      `json:"offset"`
	MaxPage   int      `json:"maxPage"`
	Total     int      `json:"total"`
	Page      int      `json:"page"`
}

type ServerListResponse {
	Response
	Data *ServerListDataResp `json:"data,omitempty"`
}

type Server {
	ServerId uint64 `json:"serverId,optional"`
	ServerBaseField
}

type ServerBaseField {
	// ServerId       uint64 `json:"serverId"`
	RegionId         uint64 `json:"regionId"`
	ServerName       string `json:"serverName"`
	Supplier         uint64 `json:"supplier"`
	GpuModel         string `json:"gpuModel"`
	GpuMem           uint64 `json:"gpuMem"`
	GpuCount         uint64 `json:"gpuCount"`
	GpuUsed          int64  `json:"gpuUsed"` // 已使用GPU数量
	CpuModel         string `json:"cpuModel"`
	CpuFrequency     int64  `json:"cpuFrequency"`
	CpuCores         uint64 `json:"cpuCores"`
	CpuCount         uint64 `json:"cpuCount"`
	Memory           uint64 `json:"memory"`
	SystemDisk       uint64 `json:"systemDisk,optional"`
	DataDisk         uint64 `json:"dataDisk,optional"`
	MaxDataDisk      uint64 `json:"maxDataDisk,optional"`
	SpeedDesc        string `json:"speedDesc,optional"`
	GpuDriver        string `json:"gpuDriver,optional"`
	CudaVersion      string `json:"cudaVersion,optional"`
	OsName           string `json:"osName,optional"`
	OsVersion        string `json:"osVersion,optional"`
	KernelVersion    string `json:"kernelVersion,optional"`
	DockerVersion    string `json:"dockerVersion,optional"`
	NvidiaDocker     int64  `json:"nvidiaDocker,optional"`
	NetworkDownSpeed int64  `json:"networkDownSpeed,optional"`
	NetworkUpSpeed   int64  `json:"networkUpSpeed,optional"`
	AgentVersion     string `json:"agentVersion,optional"`
	PayPrices        string `json:"payPrices,optional"`
	Available        uint64 `json:"available"`
	Total            uint64 `json:"total"`
	ExpireDate       uint64 `json:"expireDate"`
	ThreadCount      uint64 `json:"threadCount"`
	IsOnline         int64  `json:"isOnline,optional"`
	IsPayMin         int64  `json:"isPayMin,optional"`
	IsPayDaily       int64  `json:"isPayDaily,optional"`
	IsPayMonthly     int64  `json:"isPayMonthly,optional"`
	IsPayYearly      int64  `json:"isPayYearly,optional"`
	IsDeleted        int64  `json:"isDeleted,optional"`
	PerGpuMemory     uint64 `json:"perGpuMemory,optional"`
	PerGpuDisksize   uint64 `json:"perGpuDisksize,optional"`
	PerGpuCpuCore    uint64 `json:"perGpuCpuCore,optional"`
	FcbUrl           string `json:"fcbUrl,optional"`
}

