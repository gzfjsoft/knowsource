// ==================== async_task 队列查询 ====================
type ListAsyncTaskRequest {
	TaskType string `json:"taskType,optional"` // 任务类型筛选
	Status   string `json:"status,optional"`   // 空=全部状态；指定则精确匹配 init/running/canceled/success/failed
	PageRequest
}

type AsyncTaskItem {
	Id            int64  `json:"id"`
	ClientId      string `json:"clientId"`
	TaskType      string `json:"taskType"`
	TaskDesc      string `json:"taskDesc"`
	SourceId      int64  `json:"sourceId"`
	SourceKey     string `json:"sourceKey"`
	ExecuteResult string `json:"executeResult,optional"`
	Status        string `json:"status"`
	CreatedAt     int64  `json:"createdAt"`
	UpdatedAt     int64  `json:"updatedAt"`
}

type ListAsyncTaskData {
	List  []AsyncTaskItem `json:"list"`
	Total int64           `json:"total"`
}

type ListAsyncTaskResponse {
	Response
	Data *ListAsyncTaskData `json:"data,omitempty"`
}

type CancelAsyncTaskRequest {
	Id int64 `json:"id"` // async_task.id
}

type DeleteAsyncTaskRequest {
	Id int64 `json:"id"` // async_task.id
}

type GetAsyncTaskWatermarkRequest {
}

type GetAsyncTaskWatermarkData {
	Watermark string `json:"watermark"` // Unix 纳秒时间戳字符串；尚无变更记录时为空
}

type GetAsyncTaskWatermarkResponse {
	Response
	Data *GetAsyncTaskWatermarkData `json:"data,omitempty"`
}

//max size和模型推理  temperature、top_k、top_p、repeat_penalty；RAG 检索与重排参数
type LLMSettingData {
	MaxTokens int64 `json:"maxSize"`
	Model string `json:"model"`
	CompletionUrl string `json:"completionUrl,optional"`
	CompletionApiKey string `json:"completionApiKey,optional"`
	CompletionType string `json:"completionType,optional"`
	EmbeddingModel string `json:"embeddingModel,optional"`
	EmbeddingsUrl string `json:"embeddingsUrl,optional"`
	EmbeddingsApiKey string `json:"embeddingsApiKey,optional"`
	EmbeddingsType string `json:"embeddingsType,optional"`
	RerankerUrl string `json:"rerankerUrl,optional"`
	RerankerApiKey string `json:"rerankerApiKey,optional"`
	RerankerType string `json:"rerankerType,optional"`
	RerankerModel string `json:"rerankerModel,optional"`
	Temperature float64 `json:"temperature"`
	TopK int64 `json:"topK"`
	TopP float64 `json:"topP"`
	RepeatPenalty float64 `json:"repeatPenalty,optional"`
	// RAG：向量检索 TopK、相似度底线、重排 TopK、重排分值底线
	RagEmbeddingTopK       int64   `json:"ragEmbeddingTopK,optional"`
	RagSimilarityThreshold float64 `json:"ragSimilarityThreshold,optional"`
	// RAG：概要检索（summary collection）阈值；为空/未配置时默认沿用 RagSimilarityThreshold
	RagSummarySimilarityThreshold float64 `json:"ragSummarySimilarityThreshold,optional"`
	RagRerankTopK          int64   `json:"ragRerankTopK,optional"`
	RagRerankScoreThreshold float64 `json:"ragRerankScoreThreshold,optional"`
	// RAG：概要检索（summary collection）重排分值阈值；为空/未配置时默认沿用 RagRerankScoreThreshold
	RagSummaryRerankScoreThreshold float64 `json:"ragSummaryRerankScoreThreshold,optional"`
}
type LLMSettingResponse {
	Response
	Data *LLMSettingData `json:"data,omitempty"`
}

type LLMChatModelsData {
	ModelIds []string `json:"modelIds"`
}
type LLMChatModelsResponse {
	Response
	Data *LLMChatModelsData `json:"data,omitempty"`
}

type LLMServiceTestRequest {
	Query string `json:"query,optional"`
	Doc1  string `json:"doc1,optional"`
	Doc2  string `json:"doc2,optional"`
