type LLMServiceTestData {
	EmbeddingOk        bool      `json:"embeddingOk"`
	EmbeddingDimension int64     `json:"embeddingDimension"`
	EmbeddingError     string    `json:"embeddingError,optional"`
	RerankOk           bool      `json:"rerankOk"`
	RerankTopScore     float64   `json:"rerankTopScore,optional"`
	RerankScores       []float64 `json:"rerankScores,optional"`
	RerankError        string    `json:"rerankError,optional"`
}

type LLMServiceTestResponse {
	Response
	Data *LLMServiceTestData `json:"data,omitempty"`
}
 
