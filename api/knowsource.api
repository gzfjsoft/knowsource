	Role       string `json:"role,optional"`       // 角色编码（可选，用于筛选）
	Permission string `json:"permission,optional"` // 权限编码（可选，用于筛选）
}

type FrRolePermissionListResponse {
	Response
	Data *FrRolePermissionListData `json:"data,omitempty"`
}

type FrRolePermissionListData {
	List  []FrRolePermissionInfo `json:"list"`
	Total int64                  `json:"total"`
}

// ==================== 文档标签管理 ====================
type FrTagCreateRequest {
	Tag string `json:"tag"` // 标签名称
}

type FrTagGetRequest {
	Tag string `json:"tag"` // 标签名称
}

type FrTagGetResponse {
	Response
	Data *FrTagInfo `json:"data,omitempty"`
}

type FrTagInfo {
	Tag string `json:"tag"` // 标签名称
}

type FrTagUpdateRequest {
	OldTag string `json:"oldTag"` // 旧标签名称
	NewTag string `json:"newTag"` // 新标签名称
}

type FrTagDeleteRequest {
	Tag string `json:"tag"` // 标签名称
}

type FrTagListRequest {
	PageRequest
	Tag string `json:"tag,optional"` // 标签名称（可选，用于筛选）
}

type FrTagListResponse {
	Response
	Data *FrTagListData `json:"data,omitempty"`
}

type FrTagListData {
	List  []FrTagInfo `json:"list"`
	Total int64       `json:"total"`
}
