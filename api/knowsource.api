syntax = "v1"

info (
	title:    "knowsource Management API"
	desc:     "API for knowsource Management"
	author:   " Peter  "
	email:    "xxxxxxxx@163.com"
	version:  "v1.0.1"
	filename: "knowsource.api"
)
 
// ==================== 登录相关 ====================
type KnowsourceLoginRequest {
	ClientId string `json:"clientId"` // 企业账户名
	EmpCode  string `json:"empCode"`  // 员工编码
	Password string `json:"password"`  // 密码
	Captcha  string `json:"captcha,optional"`    // 验证码
	CaptchaId string `json:"captchaId,optional"` // 验证码ID
	IsDebug int64 `json:"isDebug,optional"` // 是否为调试模式
}

// ==================== 登录相关 ====================
type KnowsourceOALoginRequest {
	ClientId string `json:"clientId"` // 企业账户名
	UserId  string `json:"userId"`  // 用户ID
	Code string `json:"code"`  // 验证码
}


type KnowsourceLoginResponse {
	Response
	Data *KnowsourceLoginData `json:"data,omitempty"`
}

type KnowsourceLoginData {
	Token    string        `json:"token"`
	UserInfo KnowsourceEmpInfo `json:"userInfo"`
}

type KnowsourceEmpInfo {
	EmpCode    string `json:"empCode"`
	EmpName    string `json:"empName"`
	ClientId   string `json:"clientId,optional"` // 企业账户 ID（租户）
	ClientName string `json:"clientName,optional"` // 平台名称（来自 client.client_json_info.name）
	ClientDesp string `json:"clientDesp,optional"` // 平台描述（来自 client.client_json_info.desp）
	DeptCode   string `json:"deptCode"`
	DeptName   string `json:"deptName"`
	Status     int64  `json:"status"`
	Position   string `json:"position"`
	Mobile     string `json:"mobile,optional"`
	Email      string `json:"email,optional"`
	// Role       string `json:"role"`
	CreatedAt  string `json:"createdAt,optional"`
	EmpPermissions []string `json:"empPermissions,optional"`
	Roles      []string `json:"roles,optional"`
}

// ==================== 租户自助注册 / 验证 / 找回密码 / 绑定联系方式 ====================
type KnowsourceTenantRegisterRequest {
	ClientId    string `json:"clientId"`    // 企业账户名（>6 位；仅字母/数字/下划线/横线）
	CompanyName string `json:"companyName"` // 企业名称（显示名）
	OwnerEmail  string `json:"ownerEmail"`  // 邮箱（用于验证与找回）
	OwnerMobile string `json:"ownerMobile"` // 手机号（用于找回/绑定）
	Password    string `json:"password"`    // 密码：>=8 位，且包含大小写字母、数字、符号
	Desp        string `json:"desp,optional"`
}

type KnowsourceTenantRegisterData {
	ClientId   string `json:"clientId"`
	Username   string `json:"username"`   // 固定为 superadmin
	NeedVerify bool   `json:"needVerify"` // 是否已发送邮箱验证码，需调用 verify-email
}

type KnowsourceTenantRegisterResponse {
	Response
	Data *KnowsourceTenantRegisterData `json:"data,omitempty"`
}

type KnowsourceTenantVerifyEmailRequest {
	ClientId string `json:"clientId"`
	Code     string `json:"code"`
}

type KnowsourceTenantSendVerificationCodeRequest {
	ClientId string `json:"clientId"`
}

type KnowsourcePasswordResetSendCodeRequest {
	ClientId string `json:"clientId"`
	Channel  string `json:"channel"` // email | phone
	Email    string `json:"email,optional"`
	Phone    string `json:"phone,optional"`
}

type KnowsourcePasswordResetConfirmRequest {
	ClientId    string `json:"clientId"`
	Channel     string `json:"channel"` // email | phone
	Email       string `json:"email,optional"`
	Phone       string `json:"phone,optional"`
	Code        string `json:"code"`
	NewPassword string `json:"newPassword"`
}

type KnowsourceContactBindSendRequest {
	Channel   string `json:"channel"` // email | phone
	NewEmail  string `json:"newEmail,optional"`
	NewPhone  string `json:"newPhone,optional"`
}

type KnowsourceContactBindConfirmRequest {
	Channel   string `json:"channel"`
	NewEmail  string `json:"newEmail,optional"`
	NewPhone  string `json:"newPhone,optional"`
	Code      string `json:"code"`
}

// ==================== 修改密码相关 ====================
type KnowsourceChangePasswordRequest {
	EmpCode    string `json:"empCode"`    // 员工编码
	OldPassword string `json:"oldPassword"` // 旧密码
	NewPassword string `json:"newPassword"` // 新密码
}

// ==================== 员工知识库权限相关 ====================
type KnowsourceEmpDocumentTypeRequest {
	EmpCode         string `json:"empCode"`         // 员工编码
	DocumentTypeCode string `json:"documentTypeCode"` // 文档类型编码
}

type KnowsourceEmpDocumentTypeDeleteRequest {
	Id int64 `json:"id"` // 关联表主键ID
}

type KnowsourceEmpDocumentTypeListRequest {
	PageRequest
	EmpName         string `json:"empName,optional"`         // 员工姓名（可选，用于筛选）
	EmpCode         string `json:"empCode,optional"`         // 员工编码（可选，用于筛选）
	
}


type KnowsourceEmpDocumentTypeListGroupResponse {
	Response
	Data *KnowsourceEmpDocumentTypeListGroupData `json:"data,omitempty"`
}

type KnowsourceEmpDocumentTypeListGroupData {
	List  []KnowsourceEmpDocumentTypeInfoGroup `json:"list"`
	Total int64                      `json:"total"`
}
type KnowsourceEmpDocumentTypeInfoGroup {
	EmpCode           string   `json:"empCode"`
	EmpName           string   `json:"empName,optional"`
	DeptCode          string   `json:"deptCode,optional"`
	DeptName          string   `json:"deptName,optional"`
	CompanyName       string   `json:"companyName,optional"` // 员工部门编码前三位对应 fr_dept 的 CONTENT（公司名称）
	DocumentTypeCodes []string `json:"documentTypeCodes"`
	DocumentTypeNames []string `json:"documentTypeNames"`
}
type KnowsourceEmpDocumentTypeListResponse {
	Response
	Data *KnowsourceEmpDocumentTypeListData `json:"data,omitempty"`
}


type KnowsourceEmpDocumentTypeListData {
	List  []KnowsourceEmpDocumentTypeInfo `json:"list"`
	Total int64                      `json:"total"`
}

type KnowsourceEmpDocumentTypeInfo {
	Id               int64  `json:"id"`
	EmpCode          string `json:"empCode"`
	EmpName          string `json:"empName,optional"`
	DocumentTypeCode string `json:"documentTypeCode"`
	DocumentTypeName string `json:"documentTypeName,optional"`
	CreatedAt        string `json:"createdAt"`
	UpdatedAt        string `json:"updatedAt"`
}

// ==================== 部门文档类型绑定相关 ====================
type KnowsourceDeptDocumentTypeRequest {
	DeptCode         string `json:"deptCode"`         // 部门编码
	DocumentTypeCode string `json:"documentTypeCode"` // 文档类型编码
}

type KnowsourceDeptDocumentTypeDeleteRequest {
	Id int64 `json:"id"` // 关联表主键ID
}

type KnowsourceDeptDocumentTypeListRequest {
	PageRequest
	DeptCode         string `json:"deptCode,optional"`         // 部门编码（可选，用于筛选）
	DocumentTypeCode string `json:"documentTypeCode,optional"` // 文档类型编码（可选，用于筛选）
}

type KnowsourceDeptDocumentTypeListResponse {
	Response
	Data *KnowsourceDeptDocumentTypeListData `json:"data,omitempty"`
}

type KnowsourceDeptDocumentTypeListData {
	List  []KnowsourceDeptDocumentTypeInfo `json:"list"`
	Total int64                       `json:"total"`
}

type KnowsourceDeptDocumentTypeInfo {
	Id               int64  `json:"id"`
	DeptCode         string `json:"deptCode"`
	DeptName         string `json:"deptName,optional"`
	DocumentTypeCode string `json:"documentTypeCode"`
	DocumentTypeName string `json:"documentTypeName,optional"`
	CreatedAt        string `json:"createdAt"`
	UpdatedAt        string `json:"updatedAt"`
}

// ==================== 员工列表相关 ====================
type KnowsourceEmpListRequest {
	PageRequest
	EmpCode   string `json:"empCode,optional"`   // 员工编码（可选，用于筛选）
	EmpName   string `json:"empName,optional"`   // 员工姓名（可选，用于筛选）
	DeptCode  string `json:"deptCode,optional"`  // 部门编码（可选，用于筛选）
 	Status    string  `json:"status,optional"`    // 状态（可选，用于筛选）
}

type KnowsourceEmpListResponse {
	Response
	Data *KnowsourceEmpListData `json:"data,omitempty"`
}

type KnowsourceEmpListData {
	List  []KnowsourceEmpListItem `json:"list"`
	Total int64              `json:"total"`
}

type KnowsourceEmpListItem {
	EmpCode       string `json:"empCode"`       // 员工编码
	EmpName       string `json:"empName"`       // 员工姓名
	DeptCode      string `json:"deptCode"`      // 部门编码
	DeptName      string `json:"deptName,optional"`      // 部门名称
	 
	Position      string `json:"position"`     // 职位
	Status        int64  `json:"status"`       // 状态
 
	Branch        string   `json:"branch,optional"`       // 分支
	Roles         []string `json:"roles,optional"`        // 角色列表
}

// ==================== 部门列表相关 ====================
type KnowsourceDeptListRequest {
	PageRequest
	DeptCode   string `json:"deptCode,optional"`   // 部门编码（可选，用于筛选）
	DeptName   string `json:"deptName,optional"`   // 部门名称（可选，用于筛选）
	ParentCode string `json:"parentCode,optional"` // 父部门编码（可选，用于筛选）
	 
	Grade      int64  `json:"grade,optional"`    // 级别（可选，用于筛选）
}

type KnowsourceDeptListResponse {
	Response
	Data *KnowsourceDeptListData `json:"data,omitempty"`
}

type KnowsourceDeptListData {
	List  []KnowsourceDeptListItem `json:"list"`
	Total int64               `json:"total"`
}

type KnowsourceDeptListItem {
	DeptCode   string `json:"deptCode"`   // 部门编码
	DeptName   string `json:"deptName"`   // 部门名称
	ParentCode string `json:"parentCode"` // 父部门编码
	GSDM       string `json:"gsdm"`      // 公司代码
	Grade      int64  `json:"grade"`     // 级别
	EndMark    string `json:"endMark"`   // 结束标记
	Kind       string `json:"kind"`      // 类型
	B0110      string `json:"b0110,optional"` // 备注
}

// ==================== 部门增删改 ====================
type KnowsourceDeptCreateRequest {
	DeptCode   string `json:"deptCode"`             // 部门编码
	DeptName   string `json:"deptName"`             // 部门名称
	ParentCode string `json:"parentCode,optional"`  // 父部门编码
	GSDM       string `json:"gsdm,optional"`        // 公司代码
	Grade      int64  `json:"grade,optional"`       // 级别
	EndMark    string `json:"endMark,optional"`     // 结束标记
	Kind       string `json:"kind,optional"`        // 类型
	B0110      string `json:"b0110,optional"`       // 备注
}

type KnowsourceDeptUpdateRequest {
	DeptCode   string `json:"deptCode"`             // 部门编码（主键）
	DeptName   string `json:"deptName"`             // 部门名称
	ParentCode string `json:"parentCode,optional"`  // 父部门编码
	GSDM       string `json:"gsdm,optional"`        // 公司代码
	Grade      int64  `json:"grade,optional"`       // 级别
	EndMark    string `json:"endMark,optional"`     // 结束标记
	Kind       string `json:"kind,optional"`        // 类型
	B0110      string `json:"b0110,optional"`       // 备注
}

type KnowsourceDeptDeleteRequest {
	DeptCode string `json:"deptCode"` // 部门编码
	Cascade  uint64 `json:"cascade,optional"` // 1: 删除整棵子树；0/空: 仅删除当前（若有子部门则失败）
}

type KnowsourceDeptMoveRequest {
	DeptCode      string `json:"deptCode"`                 // 要移动的部门编码
	NewParentCode string `json:"newParentCode,optional"`   // 新父部门编码；空表示移动为根节点
}

// ==================== 员工增删改 ====================
type KnowsourceEmpCreateRequest {
	EmpCode  string `json:"empCode"`             // 员工编码
	EmpName  string `json:"empName"`             // 员工姓名
	DeptCode string `json:"deptCode"`            // 部门编码
	Position string `json:"position,optional"`   // 职位
	Status   int64  `json:"status,optional"`     // 状态（0启用/1禁用），默认0
	Branch   string `json:"branch,optional"`     // 分支
	Mobile   string `json:"mobile,optional"`
	Email    string `json:"email,optional"`
}

type KnowsourceEmpUpdateRequest {
	EmpCode  string `json:"empCode"`             // 员工编码（主键）
	EmpName  string `json:"empName"`             // 员工姓名
	DeptCode string `json:"deptCode"`            // 部门编码
	Position string `json:"position,optional"`   // 职位
	Status   int64  `json:"status,optional"`     // 状态（0启用/1禁用）
	Branch   string `json:"branch,optional"`     // 分支
	Mobile   string `json:"mobile,optional"`
	Email    string `json:"email,optional"`
}

type KnowsourceEmpDeleteRequest {
	EmpCode string `json:"empCode"` // 员工编码
}

// ==================== 部门树相关 ====================
type KnowsourceDeptTreeRequest {
	GSDM       string `json:"gsdm,optional"`       // 公司代码（可选，用于筛选）
	ParentCode string `json:"parentCode,optional"`  // 父部门编码（可选，用于筛选）
}

type KnowsourceDeptTreeResponse {
	Response
	Data *KnowsourceDeptTreeData `json:"data,omitempty"`
}

type KnowsourceDeptTreeData {
	Tree []KnowsourceDeptTreeNode `json:"tree"`
}

type KnowsourceDeptTreeNode {
	DeptCode   string                `json:"deptCode"`   // 部门编码
	DeptName   string                `json:"deptName"`   // 部门名称
	ParentCode string                `json:"parentCode"` // 父部门编码
	GSDM       string                `json:"gsdm"`      // 公司代码
	Grade      int64                 `json:"grade"`     // 级别
	EndMark    string                `json:"endMark"`   // 结束标记
	Kind       string                `json:"kind"`      // 类型
	B0110      string                `json:"b0110,optional"` // 备注
	Children   []KnowsourceDeptTreeNode   `json:"children"`   // 子部门列表
}

// ==================== 管理员重置密码 ====================
type AdminResetPasswordRequest {
	EmpCode string `json:"empCode"` // 员工编码
	Password string `json:"password"` // 新密码
}

type AdminSetRoleRequest {	
	EmpCode string `json:"empCode"` // 员工编码
	Role string `json:"role"` // 角色
}

// ==================== Client 管理（系统管理）====================
type AdminClientCreateRequest {
	ClientId       string `json:"clientId"` // 要创建的 clientId
	Name           string `json:"name"` // client 名称
	Desp           string `json:"desp,optional"` // 描述
	OwnerEmail     string `json:"ownerEmail,optional"` // 负责人邮箱（可选）
}

type AdminClientDeleteRequest {
	ClientId string `json:"clientId"` // 要删除的 clientId
}

type AdminClientInfo {
	ClientId       string `json:"clientId"`
	Name           string `json:"name"`
	Desp           string `json:"desp,optional"`
	ClientJsonInfo string `json:"clientJsonInfo,optional"` // 便于排查，前端可不展示
	CreatedAt      string `json:"createdAt,optional"`
	UpdatedAt      string `json:"updatedAt,optional"`
}

type AdminClientListRequest {
	PageRequest
	ClientId string `json:"clientId,optional"` // 模糊筛选
}

type AdminClientListData {
	List  []AdminClientInfo `json:"list"`
	Total int64             `json:"total"`
}

type AdminClientListResponse {
	Response
	Data *AdminClientListData `json:"data,omitempty"`
}

type BlogItem {
	Id          int64  `json:"id"`
	Title       string `json:"title"`
	Alias       string `json:"alias,optional"`
	Summary     string `json:"summary,optional"`
	Content     string `json:"content,optional"`
	Tags        string `json:"tags,optional"`
	Categories  string `json:"categories,optional"`
	Authors     string `json:"authors,optional"`
	Banner      string `json:"banner,optional"`
	IsPublished int64  `json:"isPublished"`
	CreatedAt   int64  `json:"createdAt"`
	UpdatedAt   int64  `json:"updatedAt"`
}

type BlogListPublicRequest {
	PageRequest
	Keyword string `json:"keyword,optional"`
}

type BlogAdminListRequest {
	PageRequest
	Keyword     string `json:"keyword,optional"`
	IsPublished int64  `json:"isPublished,optional"` // -1=全部,0=未发布,1=已发布
}

type BlogListData {
	List  []BlogItem `json:"list"`
	Total int64      `json:"total"`
}

type BlogListResponse {
	Response
	Data *BlogListData `json:"data,omitempty"`
}

type BlogReadRequest {
	Slug string `path:"slug"` // alias 或 id
}

type BlogReadResponse {
	Response
	Data *BlogItem `json:"data,omitempty"`
}

type BlogAdminGetRequest {
	Id int64 `json:"id"`
}

type BlogAdminCreateRequest {
	Title       string `json:"title"`
	Alias       string `json:"alias,optional"` // 别名，唯一
	Summary     string `json:"summary,optional"`
	Content     string `json:"content"`
	Tags        string `json:"tags,optional"`
	Categories  string `json:"categories,optional"`
	Authors     string `json:"authors,optional"`
	Banner      string `json:"banner,optional"`
	IsPublished int64  `json:"isPublished,optional"` // 0/1
}

type BlogAdminUpdateRequest {
	Id          int64  `json:"id"`
	Title       string `json:"title"`
	Alias       string `json:"alias,optional"` // 别名，唯一
	Summary     string `json:"summary,optional"`
	Content     string `json:"content"`
	Tags        string `json:"tags,optional"`
	Categories  string `json:"categories,optional"`
	Authors     string `json:"authors,optional"`
	Banner      string `json:"banner,optional"`
	IsPublished int64  `json:"isPublished,optional"` // 0/1
}

type BlogAdminDeleteRequest {
	Id int64 `json:"id"`
}

// ==================== 删除Client ====================


// ==================== API路由定义 ====================
@server (
	prefix:     /api/knowsource
	group:      knowsource
	timeout:    60s
)
service fca-api {
	@doc "员工登录"
	@handler KnowsourceLogin
	post /login (KnowsourceLoginRequest) returns (KnowsourceLoginResponse)



	@doc "员工登录"
	@handler KnowsourceOALogin
	post /oa/login (KnowsourceOALoginRequest) returns (KnowsourceLoginResponse)

	@doc "租户自助注册（创建 client + superadmin，发邮箱验证码）"
	@handler KnowsourceTenantRegister
	post /tenant/register (KnowsourceTenantRegisterRequest) returns (KnowsourceTenantRegisterResponse)

	@doc "租户邮箱验证通过"
	@handler KnowsourceTenantVerifyEmail
	post /tenant/verify-email (KnowsourceTenantVerifyEmailRequest) returns (Response)

	@doc "租户发送邮箱验证码"
	@handler KnowsourceTenantSendVerificationCode
	post /tenant/send-verification-code (KnowsourceTenantSendVerificationCodeRequest) returns (Response)

	@doc "忘记密码：发送验证码（邮箱或手机）"
	@handler KnowsourcePasswordResetSendCode
	post /password/reset/send-code (KnowsourcePasswordResetSendCodeRequest) returns (Response)

	@doc "忘记密码：验证码重置"
	@handler KnowsourcePasswordResetConfirm
	post /password/reset/confirm (KnowsourcePasswordResetConfirmRequest) returns (Response)

	@doc "标注文档已转化"
	@handler MarkDocumentConverted
	post /mark/document/converted (MarkDocumentConvertedRequest) returns (Response)

		@doc "标注文档已转化"
	@handler MarkDocumentRaged
	post /mark/document/raged (MarkDocumentRagedRequest) returns (Response)

	@doc "公开博客列表（无需登录）"
	@handler BlogListPublic
	post /blog/list (BlogListPublicRequest) returns (BlogListResponse)

	@doc "公开博客详情（通过 alias 或 id，无需登录）"
	@handler BlogRead
	get /blog/:slug (BlogReadRequest) returns (BlogReadResponse)

}

type AdminChangeFileDocumentTypeRequest {
	FileName string `json:"fileName"`
	OldDocumentCode string `json:"oldDocumentCode"`
	NewDocumentCode string `json:"newDocumentCode"`
}

// sys/check 各依赖服务状态
type SysCheckItem {
	Ok       bool     `json:"ok"`                 // 是否可访问
	Value    string   `json:"value"`              // 配置值/地址（脱敏可选）
	Message  string   `json:"message"`            // 错误信息或 ok 时的说明
	ModelIds []string `json:"modelIds,optional"`  // vLLM /v1/models 返回的 model id 列表（仅 vllm* 服务有值）
	Type     string   `json:"type,optional"`      // 服务类型：ollama 或 vllm（仅 completion 类服务有值）
	Version  string   `json:"version,optional"`    // 版本号（如 0.1，仅支持 /api/version 或 /version 的服务有值）
}
type SysCheckData {
	Vllmchat     SysCheckItem `json:"vllmchat"`
	Vllmembedding SysCheckItem `json:"vllmembedding"`
	Vllmreranker  SysCheckItem `json:"vllmreranker"`
	Qdrant       SysCheckItem `json:"qdrant"`
	Redis        SysCheckItem `json:"redis"`
	Mysql        SysCheckItem `json:"mysql"`
	Mineru       SysCheckItem `json:"mineru"`
	Mail         SysCheckItem `json:"mail"`
}
type SysCheckResponse {
	Response
	Data *SysCheckData `json:"data,omitempty"`
}

// ==================== AI 调用统计 ====================
type AiCallStatsQueryRequest {
	StartTime string `json:"startTime"` // 开始时间，格式 2006-01-02 或 2006-01-02 15:04:05
	EndTime   string `json:"endTime"`   // 结束时间，格式 2006-01-02 或 2006-01-02 15:04:05
}

type AiCallStatsQueryData {
	TotalCount  int64    `json:"totalCount"`  // 调用总次数
	UserCount   int64    `json:"userCount"`   // 去重用户数
	ModelCount  int64    `json:"modelCount"`  // 模型种类数
	AvgCostMs   float64  `json:"avgCostMs"`   // 平均耗时（毫秒）
	SumQuestionCharCount int64 `json:"sumQuestionCharCount"` // 问题总字数
	SumOutputCharCount   int64 `json:"sumOutputCharCount"`   // 输出总字数
	ModelNames  []string `json:"modelNames"`  // 模型名称列表（可选，便于前端展示）
}

type AiCallStatsQueryResponse {
	Response
	Data *AiCallStatsQueryData `json:"data,omitempty"`
}

// ==================== 系统统计 ====================
type SystemStatsResponse {
	Response
	Data *SystemStatsData `json:"data,omitempty"`
}

type SystemStatsData {
	EmpCount     int64 `json:"empCount"`     // 员工总数
	DeptCount    int64 `json:"deptCount"`    // 部门总数
	DocumentCount int64 `json:"documentCount"` // 知识库总数
	SessionCount  int64 `json:"sessionCount"`  // AI 会话数
}

@server (
	prefix:     /api/knowsource
	group:      knowsource
	middleware: Auth
	timeout:    120s
)
service fca-api {
	@doc "convert document to markdown"
	@handler ConvertDocumentToMD
	post /document/convert/to/md (ConvertDocumentToMDRequest) returns (ConvertDocumentToMDResponse)


	@doc "convert document to zip"
	@handler ConvertDocumentToZIP
	post /document/convert/to/zip (ConvertDocumentToMDRequest) returns (ConvertDocumentToZIPResponse)

	@doc "cancel convert task"
	@handler CancelConvertDocument
	post /document/convert/cancel (CancelConvertDocumentRequest) returns (Response)

	@doc "list async tasks for current tenant"
	@handler ListAsyncTask
	post /async-task/list (ListAsyncTaskRequest) returns (ListAsyncTaskResponse)

	@doc "cancel async task for current tenant"
	@handler CancelAsyncTask
	post /async-task/cancel (CancelAsyncTaskRequest) returns (Response)

	@doc "delete async task for current tenant"
	@handler DeleteAsyncTask
	post /async-task/delete (DeleteAsyncTaskRequest) returns (Response)

	@doc "async_task 变更水印（按租户 Redis），前端轮询与本地比较，有变化再拉列表"
	@handler GetAsyncTaskWatermark
	post /async-task/watermark (GetAsyncTaskWatermarkRequest) returns (GetAsyncTaskWatermarkResponse)

}
@server (
	prefix:     /api/knowsource
	group:      knowsource
	middleware: Auth
	timeout:    60s
)

service fca-api {

	@doc "刷新token"
	@handler RefreshToken
	post /refresh/token  returns (KnowsourceLoginResponse)

	@doc "绑定手机/邮箱：发送验证码"
	@handler KnowsourceContactBindSend
	post /profile/contact/bind/send (KnowsourceContactBindSendRequest) returns (Response)

